{
  "name": "poppata-bot",
  "version": "0.1.0",
  "description": "Telegram bot to track an infant's activities from natural-language messages",
  "type": "module",
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "dev:local": "tsx src/dev.ts",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "migrate:create": "node-pg-migrate -m migrations create --",
    "migrate:up": "node-pg-migrate -m migrations up",
    "migrate:down": "node-pg-migrate -m migrations down",
    "migrate:retry": "node-pg-migrate -m migrations retry",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check",
    "lint:apply": "biome check --write",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint:apply && npm run typecheck && npm run test"
  },
  "license": "ISC",
  "dependencies": {
    "@vercel/node": "^5.3.24",
    "luxon": "^3.5.0",
    "pg": "^8.16.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@types/luxon": "^3.4.2",
    "@types/node": "^24.1.0",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "3.2.4",
    "dotenv": "^17.2.3",
    "node-pg-migrate": "^8.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
  }
}
